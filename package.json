{
    "name": "@rrulenet/n8n-nodes-rrulenet",
    "version": "0.1.1",
    "description": "n8n community node for rrule.net advanced schedules.",
    "license": "MIT",
    "author": {
        "name": "rrule.net"
    },
    "homepage": "https://github.com/rrulenet/n8n-nodes-rrulenet#readme",
    "keywords": [
        "n8n-community-node-package",
        "n8n",
        "rrule",
        "recurrence",
        "schedule",
        "timezone"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rrulenet/n8n-nodes-rrulenet.git"
    },
    "bugs": {
        "url": "https://github.com/rrulenet/n8n-nodes-rrulenet/issues"
    },
   "scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
    "files": [
        "dist",
        "!dist/**/*.tsbuildinfo"
    ],
    "publishConfig": {
        "access": "public"
    },
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/RruleNetApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/RruleNetScheduleTrigger/RruleNetScheduleTrigger.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}
